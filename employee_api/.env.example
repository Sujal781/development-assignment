# Copy this file to .env and adjust values as needed.
# (You'll need python-dotenv, or just export these as real env vars,
# since this demo reads config via plain os.getenv() calls.)

# Path to the Excel file used as the employee database
EMPLOYEE_EXCEL_PATH=data/employees.xlsx

# External endpoint this API POSTs an employee record to
# Default below just echoes back whatever you send it - good for testing.
EXTERNAL_SEND_API_URL=https://httpbin.org/post

# External endpoint this API GETs records from to sync/import
# Default below is free fake-data API - good for testing.
EXTERNAL_FETCH_API_URL=https://jsonplaceholder.typicode.com/users
